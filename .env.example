# Nomi.ai API Configuration
# Copy this file to .env and fill in your values

# Your Nomi.ai API key (get it from https://nomi.ai Integration section)
NOMI_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: Custom API endpoint (defaults to https://api.nomi.ai)
# NOMI_API_ENDPOINT=https://api.nomi.ai

# Optional: API version (defaults to v1)
# NOMI_API_VERSION=v1

